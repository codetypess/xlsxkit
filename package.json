{
  "name": "typedsheet",
  "version": "1.1.0",
  "description": "Build typed assets from xlsx workbooks.",
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codetypess/typedsheet.git"
  },
  "bugs": {
    "url": "https://github.com/codetypess/typedsheet/issues"
  },
  "homepage": "https://github.com/codetypess/typedsheet#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "type": "module",
  "dependencies": {
    "fastxlsx": "^1.2.1",
    "json5": "^2.2.3",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "zod": "^4.1.12"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check",
    "test": "tsx test/test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.12.0",
    "eslint": "^9.29.0",
    "typescript-eslint": "^8.34.1"
  }
}
