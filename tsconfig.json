{
  "compilerOptions": {
    "module": "es2022",
    "target": "es2022",
    "strict": true,
    "moduleResolution": "bundler",
    "noEmitHelpers": true,
    "noImplicitOverride": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "./",
  ],
  "exclude": [
    "build/"
  ]
}